# Minimal image to validate headless Xorg + NVIDIA GLX rendering inside a container
# (known-risks.md "Headless Xorg inside Docker with NVIDIA"). Deliberately does NOT
# install an NVIDIA driver package: nvidia_drv.so, libGLX_nvidia and friends are
# injected by the NVIDIA Container Toolkit at run time when the container requests the
# graphics/display driver capabilities. Run with:
#
#   docker run --rm --gpus all -e NVIDIA_DRIVER_CAPABILITIES=all xtest <cmd>
FROM debian:trixie-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
        xserver-xorg-core \
        xserver-xorg-legacy \
        xinit \
        x11-xserver-utils \
        mesa-utils \
        mesa-utils-bin \
        ffmpeg \
        procps \
    && rm -rf /var/lib/apt/lists/*

# Allow Xorg to start without a seat/console (headless, container root).
RUN printf 'allowed_users=anybody\nneeds_root_rights=yes\n' > /etc/X11/Xwrapper.config

COPY worker/xorg/xorg.conf /etc/X11/xorg.conf

CMD ["bash"]
