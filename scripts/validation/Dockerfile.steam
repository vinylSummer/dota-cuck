# Image for V4/V5 — extends the headless-GPU xtest base (Dockerfile.xtest) with the
# Steam client + Dota launch toolchain. Like the base, it installs NO NVIDIA driver
# package: nvidia_drv.so / GLX / NVENC are injected by the Container Toolkit at run
# time (--gpus all -e NVIDIA_DRIVER_CAPABILITIES=all).
#
# Adds:
#   - steamcmd            (CLI Steam; same login path V2 used)
#   - steam-installer     (the GUI Steam client; bootstraps the real client on first run)
#   - python3 + python-steam==1.4.4 (the warm-session login leg of V4, matching the worker)
#   - xdotool             (drive the in-game Dota console headless on :99 in V5)
#
# Build (the runners do this for you):
#   docker build -f scripts/validation/Dockerfile.xtest -t dota-xtest .
#   docker build -f scripts/validation/Dockerfile.steam -t dota-steam .
#
# GUI Steam is i386 + non-free; first launch downloads the client and almost certainly
# needs a one-time human mobile-confirmation tap (that's exactly what V4 characterizes).
FROM dota-xtest

# steamcmd + the GUI steam launcher install into /usr/games, which is not on the default
# non-login PATH — add it so `steam` / `steamcmd` resolve in the probes' bash -c.
ENV PATH="/usr/games:${PATH}"

# Steam is 32-bit and lives in non-free. steamcmd + steam-installer both gate on an
# interactive debconf license prompt that would hang a non-interactive build — pre-accept.
ENV DEBIAN_FRONTEND=noninteractive
RUN dpkg --add-architecture i386 \
    && printf 'deb http://deb.debian.org/debian trixie main contrib non-free non-free-firmware\n' \
       > /etc/apt/sources.list.d/nonfree.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends debconf-utils \
    && echo "steam steam/question select I AGREE" | debconf-set-selections \
    && echo "steam steam/license note ''" | debconf-set-selections \
    && echo "steamcmd steam/question select I AGREE" | debconf-set-selections \
    && echo "steamcmd steam/license note ''" | debconf-set-selections \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        steamcmd \
        steam-installer \
        libgl1:i386 \
        libgl1-mesa-dri:i386 \
        python3 \
        python3-pip \
        python3-venv \
        xdotool \
        wmctrl \
        net-tools \
        curl \
        dbus-x11 \
        zenity \
        xfce4 \
        xfce4-terminal \
        x11vnc \
        novnc \
        websockify \
        supervisor \
        dumb-init \
        x11-utils \
        libvulkan1 \
        libvulkan1:i386 \
        mesa-vulkan-drivers \
        mesa-vulkan-drivers:i386 \
        vulkan-tools \
        libglvnd0 \
        libglvnd0:i386 \
        kmod \
        pkg-config \
        wget \
    && rm -rf /var/lib/apt/lists/*

# Replicate docker-steam-headless's GPU path: install the COMPLETE NVIDIA userspace driver
# matching the host (wolf-den runs 610.43.02) INSIDE the image, instead of relying on the
# NVIDIA Container Toolkit's partial CDI injection. The partial stack leaves steamwebhelper's
# CEF unable to render (it falls back to the "steamwebhelper is not responding" dialog); a
# full, self-consistent GL/EGL/Vulkan + 32-bit (compat32) stack fixes it. --no-kernel-modules:
# only userspace is installed (the kernel module comes from the host via --gpus all).
ARG NVIDIA_DRIVER_VERSION=610.43.02
RUN cd /tmp \
    && wget -q "https://us.download.nvidia.com/XFree86/Linux-x86_64/${NVIDIA_DRIVER_VERSION}/NVIDIA-Linux-x86_64-${NVIDIA_DRIVER_VERSION}.run" \
         -O nvidia.run \
    && chmod +x nvidia.run \
    && ./nvidia.run --silent --accept-license \
         --skip-depmod --skip-module-unload \
         --no-kernel-modules --no-kernel-module-source \
         --install-compat32-libs \
         --no-nouveau-check --no-nvidia-modprobe --no-systemd \
         --no-distro-scripts --no-rpms --no-backup \
         --no-check-for-alternate-installs \
         --no-libglx-indirect --no-install-libglvnd \
    && rm -f nvidia.run \
    && ldconfig

# System dbus daemon (the `dbus` package, vs dbus-x11 which is only the session helpers) so the
# system bus + messagebus user exist; steamwebhelper's CEF connects to it.
RUN apt-get update \
    && apt-get install -y --no-install-recommends dbus \
    && rm -rf /var/lib/apt/lists/*

# The CEF login popup only renders inside a real desktop session (xfwm4 + compositor) —
# bare Xorg/openbox failed. We replicate docker-steam-headless: a full Xfce4 session on the
# real NVIDIA Xorg :99, reached over x11vnc/noVNC for the one-time interactive login, with
# supervisord ordering the services (Xorg -> dbus/Xfce -> VNC). Steam itself is launched
# separately (docker exec) so V4 can drive the login vs auto-login phases.
#
# Steam must run NON-ROOT: srt-bwrap is not setuid, so as root it takes the privileged
# namespace path and dies. Create a worker uid that matches the host owner of the steam-data
# volume (/fard/steam, vinyl=1000) so the persisted, machine-bound token is reused verbatim.
RUN groupadd -g 1000 worker \
    && useradd -u 1000 -g 1000 -m -d /home/worker -s /bin/bash worker

COPY scripts/validation/supervisord.conf /etc/supervisord.conf
# Override the base image's headless xorg.conf with one that fakes a connected monitor (the
# base config has no display, which makes steamwebhelper fail "Could not find display info").
COPY scripts/validation/xorg.steam.conf /etc/X11/xorg.conf
COPY scripts/validation/desktop/ /usr/local/bin/
RUN chmod +x /usr/local/bin/start-dbus.sh /usr/local/bin/start-xfce.sh \
             /usr/local/bin/start-vnc.sh /usr/local/bin/start-novnc.sh

# Headless first-run gate: /usr/games/steam shows an interactive zenity --question
# ("Install"/"Cancel", default Cancel) before it will download the real client, which
# nothing can answer on a headless :99 — so the bootstrap never happens. Shadow zenity
# with a stub that auto-accepts that one install --question (exit 0 = "Install") and
# passes every other invocation through to the real zenity. /usr/local/bin precedes
# /usr/bin on PATH, so this wins for the wrapper's `command -v zenity`.
RUN printf '#!/bin/sh\nfor a in "$@"; do [ "$a" = "--question" ] && exit 0; done\nexec /usr/bin/zenity "$@"\n' \
        > /usr/local/bin/zenity \
    && chmod +x /usr/local/bin/zenity

# python-steam pinned to the worker's line (protobuf-3.20 / Python 3.x). Installed into
# a venv so it doesn't fight the system packages; the probes call /opt/steam-venv/bin/python.
RUN python3 -m venv /opt/steam-venv \
    && /opt/steam-venv/bin/pip install --no-cache-dir "steam[client]==1.4.4"

CMD ["bash"]
