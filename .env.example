# Copy to .env and fill in. .env is gitignored; never commit real secrets.

# === Control plane ===

# PostgreSQL connection string used by the control plane at runtime.
DATABASE_URL=postgres://dota:dota@postgres:5432/dota?sslmode=disable

# HMAC secret for signing JWTs. Generate: openssl rand -hex 32
JWT_SECRET=

# Server-wide pepper mixed into password hashing and credential key
# derivation. Never stored in the DB; losing it invalidates all logins.
# Generate: openssl rand -hex 32
CREDENTIAL_PEPPER=

# Listen addresses (defaults shown). HTTP serves /api and /ws; gRPC serves workers.
HTTP_LISTEN_ADDR=:42000
GRPC_LISTEN_ADDR=:42010

# Public base URL used to build each session's WebRTC/WHEP URL pushed to the
# browser ({PUBLIC_BASE_URL}/webrtc/{path}). Match the nginx server_name.
PUBLIC_BASE_URL=https://dota.example.com

# Where to read migration files at boot (idempotent). Default suits the image.
# MIGRATIONS_DIR=db/migrations

# === Postgres container ===

POSTGRES_USER=dota
POSTGRES_PASSWORD=dota
POSTGRES_DB=dota

# === Worker ===

# Where the worker dials the control plane's gRPC server.
CONTROL_PLANE_ADDR=control-plane:42010
DISPLAY=:99
SCREEN=1280x720

# Enable the full Dota bring-up (GUI Steam login + launch + GUI spectate +
# FFmpeg). Requires the desktop/Xorg/uinput/GPU container stack. 0/unset = the
# worker serves friends/link/match-id and stops spectate at the handoff.
WORKER_DOTA_BRINGUP=1

# mediamtx SRT ingest the worker's FFmpeg publishes to.
MEDIAMTX_SRT_HOST=mediamtx
MEDIAMTX_SRT_PORT=8890

# === Tests (optional) ===

# Point DB-backed Go tests at an existing PostgreSQL instead of the
# ephemeral cluster `make test-go` spins up. Leave unset to use that.
# POSTGRESQL_URL=postgres://postgres@localhost:5432/postgres
