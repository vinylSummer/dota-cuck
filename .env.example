# Copy to .env and fill in. .env is gitignored; never commit real secrets.

# === Control plane ===

# PostgreSQL connection string used by the control plane at runtime.
DATABASE_URL=postgres://dota:dota@postgres:5432/dota?sslmode=disable

# HMAC secret for signing JWTs. Generate: openssl rand -hex 32
JWT_SECRET=

# Server-wide pepper mixed into password hashing and credential key
# derivation. Never stored in the DB; losing it invalidates all logins.
# Generate: openssl rand -hex 32
CREDENTIAL_PEPPER=

# Listen addresses (defaults shown). HTTP serves /api and /ws; gRPC serves workers.
HTTP_LISTEN_ADDR=:42000
GRPC_LISTEN_ADDR=:42010

# === Postgres container ===

POSTGRES_USER=dota
POSTGRES_PASSWORD=dota
POSTGRES_DB=dota

# === Worker ===

# Where the worker dials the control plane's gRPC server.
CONTROL_PLANE_ADDR=control-plane:42010
DISPLAY=:99

# === Tests (optional) ===

# Point DB-backed Go tests at an existing PostgreSQL instead of the
# ephemeral cluster `make test-go` spins up. Leave unset to use that.
# POSTGRESQL_URL=postgres://postgres@localhost:5432/postgres
